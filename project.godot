; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[android]

config/package="com.horseshooter.game"
config/name="HorseShooter"
config/version_code=1
config/version_name="1.0"
export/include_debug_symbols=false

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="HorseShooter"
config/description="An Android open-world RPG about a player-named gunslinger who hates horses"
config/version="1.0.0"
run/main_scene="res://scenes/app/app_root.tscn"
config/features=PackedStringArray("4.6", "Mobile")
boot_splash/bg_color=Color(0.141176, 0.141176, 0.141176, 1)
config/icon="res://assets/sprites/icon.png"

[audio]

driver/enable_audio=true
bus/0/name="Master"
bus/0/solo=false
bus/0/mute=false
bus/0/volume_db=0.0
bus/1/name="Music"
bus/1/solo=false
bus/1/mute=false
bus/1/volume_db=0.0
bus/1/send="Master"
bus/2/name="SFX"
bus/2/solo=false
bus/2/mute=false
bus/2/volume_db=0.0
bus/2/send="Master"
bus/3/name="UI"
bus/3/solo=false
bus/3/mute=false
bus/3/volume_db=0.0
bus/3/send="Master"

[autoload]

SaveManager="res://src/save/save_manager.gd"
DialogueManager="res://src/dialogue/dialogue_manager.gd"
ContentDatabase="res://src/content/content_database.gd"
QuestManager="res://src/quests/quest_manager.gd"
InventoryManager="res://src/inventory/inventory_manager.gd"
ProgressionManager="res://src/progression/progression_manager.gd"
FollowerManager="res://src/followers/follower_manager.gd"
SettlementManager="res://src/settlement/settlement_manager.gd"
CombatDirector="res://src/combat/combat_director.gd"
FactionManager="res://src/factions/faction_manager.gd"
GameManager="res://src/game_manager.gd"
AudioManager="res://src/audio_manager.gd"
ObjectPool="res://src/spawn_pool.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=4

[export]

export_presets/presets=PackedStringArray("res://export_presets.cfg")

